# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Database (Better Auth) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://bizos:bizos_dev@localhost:5433/bizos

# ─── Auth ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-32-char-secret-minimum

# ─── Email (Resend — logs to console when not configured) ─────────────────────
# Create an API key at https://resend.com/api-keys
# Verify your sending domain, then use e.g. BizOS <noreply@yourdomain.com>
RESEND_API_KEY=
RESEND_FROM="BizOS <noreply@yourdomain.com>"

# ─── Storage (MinIO local / R2 prod) — used for image URL fallback in the browser ─
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000/bizos-uploads
